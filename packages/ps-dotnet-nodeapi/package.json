{
  "name": "@sysutils/ps-dotnet-nodeapi",
  "version": "0.1.0",
  "description": "In-process .NET backend for @sysutils/ps, loaded via node-api-dotnet",
  "main": "index.js",
  "type": "commonjs",
  "os": [
    "win32",
    "linux",
    "darwin"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "bin/win-x64/*",
    "bin/win-arm64/*",
    "bin/linux-x64/*",
    "bin/linux-arm64/*",
    "bin/osx-x64/*",
    "bin/osx-arm64/*",
    "index.js",
    "binaries.json",
    "SysUtils.Ps.NodeApi.csproj",
    "PsModule.cs"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "build:all": "node scripts/build-all.js"
  },
  "optionalDependencies": {
    "node-api-dotnet": "0.9.21"
  },
  "license": "MIT"
}
