{
  "name": "@sysutils/ps-dotnet",
  "version": "0.0.0",
  "description": "Native .NET backend for @sysutils/ps.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "bin",
    "index.js",
    "index.d.ts",
    "binaries.json",
    "*.csproj",
    "Program.cs"
  ],
  "scripts": {
    "build": "dotnet publish -c Release -o ./bin/intermediate",
    "build:all": "node scripts/build-all.js",
    "test": "dotnet test --no-build --verbosity minimal"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
