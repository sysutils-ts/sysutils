{
  "name": "@sysutils/ps-rust",
  "version": "0.0.0",
  "description": "Native Rust backend for @sysutils/ps.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "bin",
    "index.js",
    "index.d.ts",
    "binaries.json",
    "Cargo.toml",
    "src"
  ],
  "scripts": {
    "build": "cargo build --release --bin ps",
    "build:all": "node scripts/build-all.js",
    "test": "cargo test"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
