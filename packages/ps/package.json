{
  "name": "@sysutils/ps",
  "version": "1.0.0",
  "description": "Fast, cross-platform process listing as a Node.js Readable stream.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/index.mjs",
    "dist/index.mjs.map",
    "dist/index.d.mts",
    "dist/index.d.mts.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sysutils-ts/sysutils.git",
    "directory": "packages/ps"
  },
  "bugs": {
    "url": "https://github.com/sysutils-ts/sysutils/issues"
  },
  "homepage": "https://github.com/sysutils-ts/sysutils/tree/main/packages/ps#readme",
  "tsdown": {
    "entry": [
      "src/index.ts",
      "src/index.test.ts",
      "src/nodeapi.test.ts",
      "src/benchmark.test.ts"
    ],
    "dts": true,
    "sourcemap": true
  },
  "scripts": {
    "build": "tsdown",
    "build:tsdown": "tsdown",
    "build:cli": "node scripts/build-cli.ts",
    "build:nodeapi": "node scripts/build-nodeapi.ts",
    "build:all": "node scripts/build-native-all.ts && tsdown",
    "test": "node scripts/run-tests.ts",
    "test:dotnet": "dotnet test native/tests/SysUtils.Ps.Tests.csproj",
    "typecheck": "tsc --noEmit",
    "benchmark": "node scripts/benchmark.ts"
  },
  "optionalDependencies": {
    "node-api-dotnet": "0.9.21"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "0.22.4",
    "typescript": "^5.5.0"
  }
}
