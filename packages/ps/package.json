{
  "name": "@sysutils/ps",
  "version": "0.1.0",
  "description": "Cross-platform process listing as a Node.js Readable stream.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/index.mjs",
    "dist/index.mjs.map",
    "dist/index.d.mts",
    "dist/index.d.mts.map"
  ],
  "tsdown": {
    "entry": [
      "src/index.ts",
      "src/index.test.ts"
    ],
    "dts": true,
    "sourcemap": true
  },
  "scripts": {
    "build": "tsdown",
    "test": "node --test dist/index.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "optionalDependencies": {
    "@sysutils/ps-dotnet": "^0.1.0",
    "@sysutils/ps-dotnet-nodeapi": "^0.1.0",
    "node-api-dotnet": "0.9.21"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "0.22.4",
    "typescript": "^5.5.0"
  }
}
