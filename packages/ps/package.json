{
  "name": "@sysutils/ps",
  "version": "0.1.0",
  "description": "Fast, cross-platform process listing as a Node.js Readable stream.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "binaries.json",
    "dist/index.mjs",
    "dist/index.mjs.map",
    "dist/index.d.mts",
    "dist/index.d.mts.map",
    "bin/win32/*/ps.exe",
    "bin/linux/*/ps",
    "bin/darwin/*/ps",
    "bin/nodeapi/**/*"
  ],
  "tsdown": {
    "entry": [
      "src/index.ts",
      "src/index.test.ts"
    ],
    "dts": true,
    "sourcemap": true
  },
  "scripts": {
    "build": "tsdown",
    "build:tsdown": "tsdown",
    "build:cli": "node scripts/build-cli.cjs",
    "build:nodeapi": "node scripts/build-nodeapi.cjs",
    "build:all": "node scripts/build-cli-all.cjs && node scripts/build-nodeapi-all.cjs && tsdown",
    "test": "node scripts/run-tests.cjs",
    "test:dotnet": "dotnet test native/tests/SysUtils.Ps.Tests.csproj",
    "typecheck": "tsc --noEmit"
  },
  "optionalDependencies": {
    "node-api-dotnet": "0.9.21"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "0.22.4",
    "typescript": "^5.5.0"
  }
}
